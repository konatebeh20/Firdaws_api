# Configuration Email SMTP
SMTP_ENABLED=true
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=contact@firdaws-mosque.ci
# IMPORTANT: Utilisez un mot de passe d'application Gmail de 16 caractères
# Généré depuis: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Configuration alternative (si Gmail ne fonctionne pas)
# SMTP_SERVER=smtp.office365.com
# SMTP_PORT=587

# Configuration Base de Données MySQL (Xampp)
DATABASE_URL=mysql+pymysql://root:@localhost:3306/firdaws_db
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=firdaws_db
